{
    "name": "@virketrang/cvr-api",
    "type": "module",
    "version": "1.0.1",
    "scripts": {
        "dev": "tsx watch src/index.ts --env-file=.env",
        "test": "tsx --test src/validation/__tests__/*.test.ts",
        "build": "tsc && tsc-alias",
        "start": "node dist/index.js",
        "deploy": "gcloud run deploy bech-bruun-api --project=bech-bruun-api --source . --allow-unauthenticated"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.8",
        "@hono/zod-openapi": "^1.4.0",
        "@scalar/hono-api-reference": "^0.11.8",
        "@xmldom/xmldom": "^0.9.10",
        "chalk": "^5.6.2",
        "cheerio": "^1.2.0",
        "dotenv": "^17.4.2",
        "hono": "^4.12.28",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^26.1.0",
        "eslint": "^10.6.0",
        "tsc-alias": "^1.9.0",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3"
    }
}
